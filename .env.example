# Variables for the BOT service on Railway (this repo's root).
# Set these under this service's Settings -> Variables tab.

DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_id

# Connection details for the Lavalink service deployed from the /lavalink
# folder in this repo. On Railway, set these as reference variables instead
# of typing values by hand, so they always stay in sync (replace "Lavalink"
# below with whatever you actually name that service):
#   LAVALINK_HOST=${{Lavalink.RAILWAY_PRIVATE_DOMAIN}}
#   LAVALINK_PORT=${{Lavalink.PORT}}
#   LAVALINK_PASS=${{Lavalink.LAVALINK_SERVER_PASSWORD}}
LAVALINK_HOST=your_lavalink_host
LAVALINK_PORT=2333
LAVALINK_PASS=youshallnotpass

