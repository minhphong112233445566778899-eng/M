# Variables for the LAVALINK service on Railway (not the bot service).
# Set these under this service's Settings -> Variables tab.

# Define a fixed port and point Lavalink at it via SERVER_PORT, so the bot
# service can reference the exact same value with ${{Lavalink.PORT}}
# (replace "Lavalink" with whatever you actually name this service).
PORT=2333
SERVER_PORT=${{PORT}}

# Overrides lavalink.server.password from application.yml. Generate a long
# random string for this -- do NOT use "youshallnotpass" in production.
LAVALINK_SERVER_PASSWORD=change_me_to_a_long_random_secret

# Used by the lavasrc plugin for Spotify link/search support.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Optional: cap the JVM heap to fit your Railway plan's memory limit. The
# Lavalink docs default to -Xmx6G, which will likely exceed a Railway
# free/hobby plan and get the service OOM-killed.
_JAVA_OPTIONS=-Xmx512m

# Optional, only after you've completed the YouTube OAuth device-login flow
# described in application.yml (paste the refresh token printed in this
# service's deploy logs). Editing application.yml directly and redeploying
# also works and is simpler/more reliable than relying on this env override.
# PLUGINS_YOUTUBE_OAUTH_REFRESHTOKEN=paste_your_refresh_token_here
# PLUGINS_YOUTUBE_OAUTH_SKIPINITIALIZATION=true
